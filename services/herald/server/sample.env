# Service identity
ARCHON_HERALD_NAME=name-service
ARCHON_HERALD_DOMAIN=your-domain.example
ARCHON_DRAWBRIDGE_PUBLIC_HOST=https://your-domain.example
ARCHON_HERALD_SESSION_SECRET=change-me-to-a-random-string
ARCHON_HERALD_OWNER_DID=did:cid:your-owner-did

# Server settings
ARCHON_HERALD_DB=json
ARCHON_HERALD_PORT=4230

# Archon services (use container names when running in docker)
ARCHON_GATEKEEPER_URL=http://archon-gatekeeper-1:4224
ARCHON_KEYMASTER_URL=http://archon-keymaster-1:4226
ARCHON_HERALD_WALLET_URL=http://archon-gatekeeper-1:4224
ARCHON_HERALD_WALLET_PASSPHRASE=

# IPNS publication settings (use container name for IPFS)
ARCHON_HERALD_IPFS_API_URL=http://localhost:5001/api/v0
ARCHON_HERALD_IPNS_KEY_NAME=name-service

# Membership credential schema DID
ARCHON_HERALD_MEMBERSHIP_SCHEMA_DID=did:cid:bagaaieraj6e2ygpm7laaapxuz5efo2bxi436vi6ubw42b75elsscelte6kza

# Tor SOCKS proxy for .onion Lightning endpoints (e.g. localhost:9050)
ARCHON_HERALD_TOR_PROXY=

# Admin API key for keymaster service (required when using ARCHON_KEYMASTER_URL)
# Also accepts ARCHON_ADMIN_API_KEY for backwards compatibility
ARCHON_HERALD_ADMIN_API_KEY=
