{
  "name": "@didcid/clients",
  "version": "0.1.1",
  "description": "Lightweight HTTP clients for Archon services",
  "type": "module",
  "module": "./dist/esm/index.js",
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./gatekeeper": {
      "import": "./dist/esm/gatekeeper-client.js",
      "require": "./dist/cjs/gatekeeper-client.cjs",
      "types": "./dist/types/gatekeeper-client.d.ts"
    },
    "./drawbridge": {
      "import": "./dist/esm/drawbridge-client.js",
      "require": "./dist/cjs/drawbridge-client.cjs",
      "types": "./dist/types/drawbridge-client.d.ts"
    },
    "./keymaster": {
      "import": "./dist/esm/keymaster-client.js",
      "require": "./dist/cjs/keymaster-client.cjs",
      "types": "./dist/types/keymaster-client.d.ts"
    },
    "./gatekeeper-types": {
      "types": "./dist/types/gatekeeper-types.d.ts"
    },
    "./keymaster-types": {
      "types": "./dist/types/keymaster-types.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "gatekeeper": [
        "./dist/types/gatekeeper-client.d.ts"
      ],
      "drawbridge": [
        "./dist/types/drawbridge-client.d.ts"
      ],
      "keymaster": [
        "./dist/types/keymaster-client.d.ts"
      ],
      "gatekeeper-types": [
        "./dist/types/gatekeeper-types.d.ts"
      ],
      "keymaster-types": [
        "./dist/types/keymaster-types.d.ts"
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.json",
    "bundle:cjs": "rollup -c rollup.cjs.config.js",
    "build": "npm run clean && npm run build:esm && npm run bundle:cjs"
  },
  "keywords": [
    "archon",
    "did",
    "client"
  ],
  "author": "David McFadzean <davidmc@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "rollup": "^4.60.3",
    "typescript": "^5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archetech/archon.git"
  }
}
