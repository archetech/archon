FROM node:22.15.0-bullseye-slim

WORKDIR /app

COPY package*.json ./
COPY packages/ ./packages/

RUN npm ci
RUN npm run build

COPY services/mediators/zcash ./zcash/
WORKDIR /app/zcash
RUN npm ci && npm run build

ARG GIT_COMMIT=unknown
ENV GIT_COMMIT=$GIT_COMMIT

EXPOSE 4238

CMD ["node", "dist/zcash-mediator.js"]
