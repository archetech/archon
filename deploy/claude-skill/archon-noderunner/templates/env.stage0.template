# Archon Noderunner — stage 0 (.env template)
# Placeholders {{LIKE_THIS}} are filled at install time.

# --- Identity ---
ARCHON_NODE_NAME={{NODE_NAME}}
ARCHON_NODE_ID={{NODE_ID}}
ARCHON_NODE_URL=https://{{DOMAIN}}

# --- Public surface ---
ARCHON_HOSTNAME={{DOMAIN}}
ARCHON_ADMIN_EMAIL={{ADMIN_EMAIL}}

# --- Registries: stage 0 = hyperswarm only ---
ARCHON_GATEKEEPER_REGISTRIES=hyperswarm

# --- Fallback resolution: delegate to upstream Archon ---
ARCHON_GATEKEEPER_FALLBACK_URL={{UPSTREAM_URL}}
ARCHON_GATEKEEPER_CONFIRM_FALLBACK_URL={{UPSTREAM_URL}}

# --- Storage ---
ARCHON_GATEKEEPER_DB=redis
ARCHON_KEYMASTER_DB=redis
ARCHON_REDIS_URL=redis://redis:6379

# --- Compose profiles ---
# Stage 0: minimal delegate node. add-* subcommands append to this list.
COMPOSE_PROFILES=hyperswarm,gatekeeper-client,keymaster-client,react-wallet,drawbridge

# --- Placeholders for later stages (unset by default) ---
# ARCHON_PIN_PROVIDER=
# ARCHON_PIN_API_URL=
# ARCHON_PIN_JWT=
# ARCHON_DIDCOMM_URL=
# ARCHON_LIGHTNING_MEDIATOR_URL=
