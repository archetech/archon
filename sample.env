ARCHON_ETH_MIN_GAS_BALANCE_WEI=1000000000000000
ARCHON_ETH_IMPORT_INTERVAL=1
ARCHON_ETH_EXPORT_INTERVAL=1
ARCHON_ETH_REIMPORT=true
ARCHON_ETH_DB=json
